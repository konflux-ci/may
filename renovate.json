{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    "demo/**"
  ],
  "ignoreDeps": [
    "github.com/konflux-ci/may"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "tekton"
      ],
      "prPriority": 10
    },
    {
      "groupName": "go-modules controller-runtime and k8s",
      "description": "no automerge for non-patch updates to Kubernetes dependencies",
      "matchPackageNames": [
        "k8s.io/api",
        "k8s.io/apimachinery",
        "k8s.io/client-go",
        "k8s.io/utils",
        "sigs.k8s.io/controller-runtime"
      ],
      "matchUpdateTypes": [
        "minor",
        "major",
        "digest"
      ],
      "automerge": false
    },
    {
      "groupName": "go-modules automerge",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true
    },
    {
      "groupName": "go-modules major",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major"
      ]
    }
  ],
  "gomod": {
    "enabled": true,
    "postUpdateOptions": [
      "gomodTidy"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^may/config/.*\\.yaml$/",
      "/^drivers/.*/config/.*\\.yaml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/^may/config/kustomization\\.ya?ml$/",
      "/^drivers/.*/config/kustomization\\.ya?ml$/"
    ],
    "pinDigests": false
  },
  "dockerfile": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  }
}
